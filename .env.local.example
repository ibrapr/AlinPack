# Copy this file to .env.local for local development.
# In production (Vercel), set these in Project Settings → Environment Variables.

# Password used to sign in at /admin/login
ADMIN_PASSWORD=""

# Long random string used to sign session cookies (any 32+ random chars).
# If omitted, ADMIN_PASSWORD is used as the fallback secret.
ADMIN_SESSION_SECRET=""

# GitHub-as-database (optional for local; required for production)
# Generate a personal access token with the "repo" scope at
#   https://github.com/settings/tokens?type=beta
# When these three are set, admin changes commit to your repo and Vercel
# auto-redeploys the live site. When unset, admin writes to local files.
# GITHUB_TOKEN=ghp_xxx
# GITHUB_OWNER=your-github-username
# GITHUB_REPO=alinpack-website
# GITHUB_BRANCH=main

# Contact form email delivery. Requests are always saved to
# data/content/contact-requests.json; when RESEND_API_KEY is set, they are also
# emailed to info@alinpack.com.
# RESEND_API_KEY=re_xxx
# CONTACT_FROM_EMAIL=Alin Pack Website <onboarding@resend.dev>
